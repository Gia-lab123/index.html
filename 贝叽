<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>贝叽 Badge - 手绘徽章工坊</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@200;300;400;600&family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #FDFCF8;
            --yellow: #F5B800;
            --ink: #2C2420;
        }
        
        * {
            font-family: 'Noto Serif SC', 'SimSun', serif;
            font-weight: 300;
        }
        
        .font-en {
            font-family: 'Quicksand', sans-serif;
        }
        
        body {
            background-color: var(--cream);
            color: var(--ink);
        }
        
        .logo-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--yellow);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 2px 12px rgba(245,184,0,0.3);
        }
        
        .logo-circle::after {
            content: '';
            position: absolute;
            inset: -3px;
            border-radius: 50%;
            border: 2px solid var(--yellow);
            opacity: 0.3;
        }
        
        .logo-text {
            color: white;
            font-size: 20px;
            font-weight: 700;
        }
        
        .hand-drawn-btn {
            border: 2px solid var(--ink);
            border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .hand-drawn-btn:hover {
            transform: rotate(-1deg) scale(1.02);
            box-shadow: 4px 4px 0px var(--yellow);
        }
        
        .upload-zone {
            border: 2px dashed #E8E0D5;
            border-radius: 24px;
            transition: all 0.3s ease;
            cursor: pointer;
            background: white;
        }
        
        .upload-zone:hover {
            border-color: var(--yellow);
            background: #FFFBF0;
        }
        
        .category-pill {
            border: 2px solid #F0EBE3;
            border-radius: 28px;
            padding: 10px 24px;
            font-size: 14px;
            transition: all 0.3s ease;
            cursor: pointer;
            background: white;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 400;
        }
        
        .category-pill:hover {
            border-color: var(--yellow);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(245,184,0,0.15);
        }
        
        .category-pill.active {
            border-color: var(--yellow);
            background: var(--yellow);
            color: white;
            box-shadow: 0 8px 20px rgba(245,184,0,0.3);
        }
        
        .slider-thumb::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--yellow);
            cursor: pointer;
            border: 3px solid white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }
        
        .result-container {
            background: white;
            border-radius: 32px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.06);
            border: 1px solid #F5F0E8;
        }
        
        .illustration-shadow {
            filter: drop-shadow(0 16px 32px rgba(0,0,0,0.12)) drop-shadow(0 4px 8px rgba(0,0,0,0.08));
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .illustration-shadow:hover {
            filter: drop-shadow(0 24px 48px rgba(0,0,0,0.18)) drop-shadow(0 8px 16px rgba(0,0,0,0.12));
            transform: translateY(-8px) rotate(2deg);
        }
        
        .badge-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            border: 2px solid #F5F0E8;
            transition: all 0.4s ease;
            position: relative;
        }
        
        .badge-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border-color: #FFE566;
        }
        
        .badge-card .delete-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: white;
            border: 2px solid #F0EBE3;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            opacity: 0;
            transition: all 0.3s ease;
            font-size: 18px;
            color: #999;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        .badge-card:hover .delete-btn {
            opacity: 1;
        }
        
        .badge-card .delete-btn:hover {
            background: #FF6B6B;
            color: white;
            border-color: #FF6B6B;
            transform: scale(1.1);
        }
        
        .filter-tab {
            padding: 8px 20px;
            border-radius: 24px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
            font-weight: 400;
        }
        
        .filter-tab:hover, .filter-tab.active {
            background: var(--yellow);
            color: white;
            border-color: var(--yellow);
            box-shadow: 0 4px 12px rgba(245,184,0,0.3);
        }
        
        .empty-state {
            text-align: center;
            color: #D4CFC7;
        }
        
        .spinner {
            width: 28px;
            height: 28px;
            border: 3px solid #FFF3CD;
            border-top-color: var(--yellow);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        @keyframes spin { 
            to { transform: rotate(360deg); } 
        }
        
        .paper-texture {
            background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.015'/%3E%3C/svg%3E");
        }
        
        #fileInput { 
            display: none; 
        }
        
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.3);
            backdrop-filter: blur(8px);
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        
        .modal-overlay.active {
            opacity: 1;
            pointer-events: all;
        }
        
        .modal-content {
            background: white;
            border-radius: 32px;
            padding: 40px;
            max-width: 420px;
            width: 90%;
            transform: scale(0.9) translateY(20px);
            transition: all 0.3s ease;
            box-shadow: 0 24px 60px rgba(0,0,0,0.2);
        }
        
        .modal-overlay.active .modal-content {
            transform: scale(1) translateY(0);
        }
        
        .toast {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: var(--ink);
            color: white;
            padding: 14px 28px;
            border-radius: 40px;
            font-size: 14px;
            z-index: 200;
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 12px 32px rgba(0,0,0,0.25);
        }
        
        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }
        
        .color-dot {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            border: 3px solid transparent;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .color-dot:hover {
            transform: scale(1.2);
        }
        
        .color-dot.active {
            border-color: var(--ink);
            transform: scale(1.15);
        }
        
        .color-dot.active::after {
            content: '✓';
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 14px;
            font-weight: 700;
            text-shadow: 0 1px 2px rgba(0,0,0,0.3);
        }
        
        .decoration-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.4;
            pointer-events: none;
        }
        
        .error-msg {
            color: #FF6B6B;
            font-size: 14px;
            margin-top: 8px;
        }
    </style>
</head>
<body class="paper-texture min-h-screen relative overflow-x-hidden">
    
    <div class="decoration-blob w-96 h-96 bg-yellow-200 -top-48 -right-48"></div>
    <div class="decoration-blob w-64 h-64 bg-red-200 top-1/3 -left-32"></div>
    
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-stone-100/50">
        <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="logo-circle">
                    <span class="logo-text font-en">B</span>
                </div>
                <div>
                    <h1 class="text-lg tracking-wide font-normal">贝叽</h1>
                    <p class="text-xs text-stone-400 font-en tracking-widest -mt-0.5 font-medium">BADGE</p>
                </div>
            </div>
            <div class="flex gap-8 text-sm">
                <button onclick="showSection('create')" class="tab-btn transition-colors font-normal text-stone-800" data-section="create">创作</button>
                <button onclick="showSection('gallery')" class="tab-btn text-stone-400 hover:text-stone-800 transition-colors font-normal" data-section="gallery">
                    我的徽章
                    <span id="badgeCount" class="ml-1.5 text-xs bg-yellow-400 text-white px-2 py-0.5 rounded-full hidden font-en font-bold">0</span>
                </button>
            </div>
        </div>
    </nav>

    <section id="createSection" class="max-w-5xl mx-auto px-6 py-12 relative z-10">
        
        <div class="text-center mb-12">
            <h2 class="text-4xl font-extralight mb-3 text-stone-800">制作你的插画徽章</h2>
            <p class="text-stone-400 text-sm tracking-wider">简约线条 · 明媚色彩 · 插画质感</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-10 items-start">
            
            <div class="space-y-8">
                
                <div class="result-container p-8">
                    <input type="file" id="fileInput" accept="image/*">
                    <div id="uploadTrigger" class="upload-zone p-10 text-center">
                        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-yellow-50 flex items-center justify-center">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F5B800" stroke-width="2" stroke-linecap="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="17 8 12 3 7 8"/>
                                <line x1="12" y1="3" x2="12" y2="15"/>
                            </svg>
                        </div>
                        <p class="text-stone-600 mb-1 font-normal">点击或拖拽上传照片</p>
                        <p class="text-xs text-stone-300">支持 JPG、PNG 格式</p>
                    </div>
                    <div id="thumbPreview" class="hidden mt-6 flex items-center gap-4">
                        <div class="relative">
                            <img id="thumbImg" class="w-20 h-20 object-cover rounded-2xl border-2 border-stone-100">
                            <button onclick="clearImage()" class="absolute -top-2 -right-2 w-6 h-6 bg-white rounded-full shadow-md flex items-center justify-center text-stone-400 hover:text-red-500 text-xs border border-stone-100">×</button>
                        </div>
                        <div>
                            <p class="text-sm text-stone-600 font-normal">已选择图片</p>
                            <p class="text-xs text-stone-400 mt-0.5">可开始调整参数</p>
                        </div>
                    </div>
                </div>

                <div>
                    <p class="text-xs text-stone-400 mb-4 tracking-wider uppercase font-en">Category</p>
                    <div class="flex flex-wrap gap-3" id="categoryList">
                        <span class="category-pill active" data-cat="travel"><span class="text-lg">✈️</span> 旅行</span>
                        <span class="category-pill" data-cat="pet"><span class="text-lg">🐾</span> 宠物</span>
                        <span class="category-pill" data-cat="food"><span class="text-lg">🍜</span> 美食</span>
                        <span class="category-pill" data-cat="memory"><span class="text-lg">📸</span> 纪念</span>
                    </div>
                </div>

                <div>
                    <p class="text-xs text-stone-400 mb-4 tracking-wider uppercase font-en">Color Style</p>
                    <div class="flex gap-4" id="colorList">
                        <div class="color-dot active" style="background: linear-gradient(135deg, #FF6B6B, #FFE66D);" data-palette="warm" title="暖阳"></div>
                        <div class="color-dot" style="background: linear-gradient(135deg, #4ECDC4, #A8E6CF);" data-palette="fresh" title="清新"></div>
                        <div class="color-dot" style="background: linear-gradient(135deg, #C7CEEA, #FFD3B6);" data-palette="soft" title="柔和"></div>
                        <div class="color-dot" style="background: linear-gradient(135deg, #FFD93D, #FF6B6B);" data-palette="vivid" title="鲜艳"></div>
                        <div class="color-dot" style="background: linear-gradient(135deg, #A8D8EA, #FFAAA5);" data-palette="pastel" title="马卡龙"></div>
                    </div>
                </div>

                <div id="controls" class="space-y-6 opacity-40 pointer-events-none transition-opacity">
                    <p class="text-xs text-stone-400 tracking-wider uppercase font-en">Settings</p>
                    
                    <div>
                        <div class="flex justify-between mb-2">
                            <span class="text-sm text-stone-600">线条粗细</span>
                            <span class="text-sm text-stone-400 font-en" id="strokeVal">60%</span>
                        </div>
                        <input type="range" id="strokeRange" min="30" max="100" value="60" 
                               class="w-full h-2 bg-stone-100 rounded-full appearance-none slider-thumb">
                    </div>
                    
                    <div>
                        <div class="flex justify-between mb-2">
                            <span class="text-sm text-stone-600">色彩饱和度</span>
                            <span class="text-sm text-stone-400 font-en" id="satVal">75%</span>
                        </div>
                        <input type="range" id="satRange" min="30" max="100" value="75" 
                               class="w-full h-2 bg-stone-100 rounded-full appearance-none slider-thumb">
                    </div>

                    <button id="generateBtn" class="hand-drawn-btn w-full py-4 bg-stone-800 text-white text-base tracking-widest hover:bg-stone-700 font-normal">
                        生成插画徽章
                    </button>
                    <div id="errorMsg" class="error-msg hidden"></div>
                </div>
            </div>

            <div class="lg:sticky lg:top-24">
                <div class="result-container p-10 min-h-[520px] flex flex-col items-center justify-center relative overflow-hidden">
                    
                    <div class="absolute inset-0 opacity-30">
                        <div class="absolute top-10 right-10 w-32 h-32 rounded-full bg-yellow-200 blur-3xl"></div>
                        <div class="absolute bottom-10 left-10 w-24 h-24 rounded-full bg-red-200 blur-2xl"></div>
                    </div>
                    
                    <div id="emptyState" class="empty-state relative z-10">
                        <div class="w-24 h-24 mx-auto mb-4 rounded-3xl bg-stone-50 flex items-center justify-center text-4xl border-2 border-dashed border-stone-200">
                            🎨
                        </div>
                        <p class="text-stone-400 font-normal">上传照片开始创作</p>
                    </div>

                    <div id="processing" class="hidden text-center relative z-10">
                        <div class="spinner mx-auto mb-4"></div>
                        <p class="text-sm text-stone-500">正在绘制插画风格...</p>
                    </div>

                    <div id="resultArea" class="hidden text-center w-full relative z-10">
                        <div class="mb-8 relative inline-block">
                            <canvas id="resultCanvas" class="illustration-shadow max-w-full rounded-3xl bg-white"></canvas>
                        </div>
                        
                        <div class="flex gap-4 justify-center">
                            <button onclick="saveBadge()" class="hand-drawn-btn px-8 py-3 bg-yellow-400 text-stone-800 font-normal hover:bg-yellow-500">
                                保存徽章
                            </button>
                            <button onclick="downloadBadge()" class="hand-drawn-btn px-8 py-3 border-2 border-stone-200 text-stone-600 font-normal hover:border-yellow-400">
                                下载
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="gallerySection" class="max-w-5xl mx-auto px-6 py-12 hidden relative z-10">
        
        <div class="flex justify-between items-end mb-10">
            <div>
                <h2 class="text-4xl font-extralight mb-2">我的徽章</h2>
                <p class="text-stone-400 text-sm">按分类查看你制作的所有插画徽章</p>
            </div>
            <button onclick="showSection('create')" class="hand-drawn-btn px-6 py-3 bg-stone-800 text-white font-normal hover:bg-stone-700">
                + 制作新徽章
            </button>
        </div>

        <div class="flex gap-3 mb-10 flex-wrap">
            <span class="filter-tab active" data-filter="all">全部</span>
            <span class="filter-tab" data-filter="travel">✈️ 旅行</span>
            <span class="filter-tab" data-filter="pet">🐾 宠物</span>
            <span class="filter-tab" data-filter="food">🍜 美食</span>
            <span class="filter-tab" data-filter="memory">📸 纪念</span>
        </div>

        <div id="badgeGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6"></div>

        <div id="galleryEmpty" class="hidden text-center py-20">
            <div class="text-6xl mb-4">🎨</div>
            <p class="text-stone-400 mb-2 text-lg">还没有徽章</p>
            <p class="text-sm text-stone-300">去创作页面制作你的第一个插画徽章吧</p>
        </div>
    </section>

    <div id="saveModal" class="modal-overlay">
        <div class="modal-content text-center">
            <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-yellow-100 flex items-center justify-center text-3xl">🏷️</div>
            <h3 class="text-xl mb-2 font-normal">给你的徽章起个名字</h3>
            <p class="text-sm text-stone-400 mb-6">方便你在图库中快速找到它</p>
            <input type="text" id="badgeName" placeholder="例如：京都樱花之旅" 
                   class="w-full px-5 py-4 border-2 border-stone-100 rounded-2xl text-base focus:outline-none focus:border-yellow-400 mb-6 transition-colors">
            <div class="flex gap-4">
                <button onclick="closeModal()" class="flex-1 py-3.5 border-2 border-stone-200 rounded-2xl text-sm text-stone-500 hover:bg-stone-50 font-normal">取消</button>
                <button onclick="confirmSave()" class="flex-1 py-3.5 bg-yellow-400 text-stone-800 rounded-2xl text-sm hover:bg-yellow-500 font-normal">保存</button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <script>
        var palettes = {
            warm: {
                name: '暖阳',
                colors: [
                    [255, 107, 107],
                    [255, 230, 109],
                    [255, 159, 67],
                    [255, 195, 113],
                    [199, 125, 109]
                ],
                bg: [255, 250, 240]
            },
            fresh: {
                name: '清新',
                colors: [
                    [78, 205, 196],
                    [168, 230, 207],
                    [128, 222, 234],
                    [149, 213, 178],
                    [87, 204, 153]
                ],
                bg: [240, 255, 250]
            },
            soft: {
                name: '柔和',
                colors: [
                    [199, 206, 234],
                    [255, 211, 182],
                    [255, 218, 185],
                    [230, 230, 250],
                    [255, 228, 225]
                ],
                bg: [255, 248, 245]
            },
            vivid: {
                name: '鲜艳',
                colors: [
                    [255, 217, 61],
                    [255, 107, 107],
                    [95, 39, 205],
                    [0, 210, 211],
                    [255, 159, 67]
                ],
                bg: [255, 252, 240]
            },
            pastel: {
                name: '马卡龙',
                colors: [
                    [168, 216, 234],
                    [255, 170, 165],
                    [181, 234, 215],
                    [255, 211, 182],
                    [226, 209, 249]
                ],
                bg: [255, 252, 255]
            }
        };

        var currentPalette = 'warm';
        var badges = [];
        try {
            badges = JSON.parse(localStorage.getItem('beiji_badges') || '[]');
        } catch (e) {
            badges = [];
        }
        
        var currentImage = null;
        var currentCategory = 'travel';
        var currentSketchData = null;

        document.addEventListener('DOMContentLoaded', function() {
            updateBadgeCount();
            renderGallery('all');
            initEventListeners();
        });

        function initEventListeners() {
            var fileInput = document.getElementById('fileInput');
            var uploadTrigger = document.getElementById('uploadTrigger');
            
            uploadTrigger.addEventListener('click', function() {
                fileInput.click();
            });
            
            uploadTrigger.addEventListener('dragover', function(e) {
                e.preventDefault();
                uploadTrigger.style.borderColor = '#F5B800';
                uploadTrigger.style.background = '#FFFBF0';
            });
            
            uploadTrigger.addEventListener('dragleave', function() {
                uploadTrigger.style.borderColor = '';
                uploadTrigger.style.background = '';
            });
            
            uploadTrigger.addEventListener('drop', function(e) {
                e.preventDefault();
                uploadTrigger.style.borderColor = '';
                uploadTrigger.style.background = '';
                var file = e.dataTransfer.files[0];
                if (file && file.type.startsWith('image/')) {
                    handleFile(file);
                }
            });
            
            fileInput.addEventListener('change', function(e) {
                if (e.target.files[0]) {
                    handleFile(e.target.files[0]);
                }
            });

            var pills = document.querySelectorAll('.category-pill');
            for (var i = 0; i < pills.length; i++) {
                pills[i].addEventListener('click', function() {
                    for (var j = 0; j < pills.length; j++) {
                        pills[j].classList.remove('active');
                    }
                    this.classList.add('active');
                    currentCategory = this.getAttribute('data-cat');
                });
            }

            var dots = document.querySelectorAll('.color-dot');
            for (var i = 0; i < dots.length; i++) {
                dots[i].addEventListener('click', function() {
                    for (var j = 0; j < dots.length; j++) {
                        dots[j].classList.remove('active');
                    }
                    this.classList.add('active');
                    currentPalette = this.getAttribute('data-palette');
                });
            }

            var strokeRange = document.getElementById('strokeRange');
            var satRange = document.getElementById('satRange');
            
            strokeRange.addEventListener('input', function() {
                document.getElementById('strokeVal').textContent = this.value + '%';
            });
            
            satRange.addEventListener('input', function() {
                document.getElementById('satVal').textContent = this.value + '%';
            });

            document.getElementById('generateBtn').addEventListener('click', generateSketch);

            var tabs = document.querySelectorAll('.filter-tab');
            for (var i = 0; i < tabs.length; i++) {
                tabs[i].addEventListener('click', function() {
                    for (var j = 0; j < tabs.length; j++) {
                        tabs[j].classList.remove('active');
                    }
                    this.classList.add('active');
                    renderGallery(this.getAttribute('data-filter'));
                });
            }
        }

        function handleFile(file) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = new Image();
                img.onload = function() {
                    currentImage = img;
                    document.getElementById('thumbImg').src = e.target.result;
                    document.getElementById('thumbPreview').classList.remove('hidden');
                    document.getElementById('uploadTrigger').classList.add('hidden');
                    document.getElementById('controls').classList.remove('opacity-40', 'pointer-events-none');
                };
                img.onerror = function() {
                    showError('图片加载失败，请重试');
                };
                img.src = e.target.result;
            };
            reader.onerror = function() {
                showError('文件读取失败');
            };
            reader.readAsDataURL(file);
        }

        function clearImage() {
            currentImage = null;
            document.getElementById('fileInput').value = '';
            document.getElementById('thumbPreview').classList.add('hidden');
            document.getElementById('uploadTrigger').classList.remove('hidden');
            document.getElementById('controls').classList.add('opacity-40', 'pointer-events-none');
            document.getElementById('resultArea').classList.add('hidden');
            document.getElementById('emptyState').classList.remove('hidden');
            hideError();
        }

        function showError(msg) {
            var el = document.getElementById('errorMsg');
            el.textContent = msg;
            el.classList.remove('hidden');
        }

        function hideError() {
            document.getElementById('errorMsg').classList.add('hidden');
        }

        function generateSketch() {
            if (!currentImage) {
                showError('请先上传图片');
                return;
            }
            
            hideError();
            document.getElementById('emptyState').classList.add('hidden');
            document.getElementById('processing').classList.remove('hidden');
            document.getElementById('resultArea').classList.add('hidden');

            setTimeout(function() {
                try {
                    var stroke = parseInt(document.getElementById('strokeRange').value);
                    var saturation = parseInt(document.getElementById('satRange').value);
                    
                    var tempCanvas = createIllustration(currentImage, stroke, saturation);
                    
                    if (!tempCanvas) {
                        throw new Error('生成失败');
                    }
                    
                    var resultCanvas = document.getElementById('resultCanvas');
                    resultCanvas.width = tempCanvas.width;
                    resultCanvas.height = tempCanvas.height;
                    resultCanvas.getContext('2d').drawImage(tempCanvas, 0, 0);
                    currentSketchData = resultCanvas.toDataURL('image/png');
                    
                    document.getElementById('processing').classList.add('hidden');
                    document.getElementById('resultArea').classList.remove('hidden');
                } catch (err) {
                    console.error('生成错误:', err);
                    document.getElementById('processing').classList.add('hidden');
                    document.getElementById('emptyState').classList.remove('hidden');
                    showError('生成失败: ' + err.message);
                }
            }, 100);
        }

        function createIllustration(img, strokeIntensity, saturationLevel) {
            var size = 600;
            var canvas = document.createElement('canvas');
            canvas.width = size;
            canvas.height = size;
            var ctx = canvas.getContext('2d');
            var palette = palettes[currentPalette];
            
            if (!palette) {
                throw new Error('调色板不存在');
            }
            
            // 背景色
            ctx.fillStyle = 'rgb(' + palette.bg[0] + ',' + palette.bg[1] + ',' + palette.bg[2] + ')';
            ctx.fillRect(0, 0, size, size);
            
            // 裁剪原图
            var minDim = Math.min(img.width, img.height);
            var sx = (img.width - minDim) / 2;
            var sy = (img.height - minDim) / 2;
            
            var offCanvas = document.createElement('canvas');
            offCanvas.width = size;
            offCanvas.height = size;
            var offCtx = offCanvas.getContext('2d');
            offCtx.drawImage(img, sx, sy, minDim, minDim, 0, 0, size, size);
            
            var imageData = offCtx.getImageData(0, 0, size, size);
            var data = imageData.data;
            
            // 提取主体掩码
            var mask = extractSubject(data, size, size);
            
            // 色彩量化
            var quantized = quantizeColors(data, mask, size, size, palette.colors, saturationLevel);
            
            // 绘制色块
            var output = ctx.createImageData(size, size);
            var outData = output.data;
            
            for (var i = 0; i < size * size; i++) {
                var idx = i * 4;
                if (mask[i] > 0.5) {
                    var color = quantized[i];
                    if (color && color.length === 3) {
                        outData[idx] = color[0];
                        outData[idx + 1] = color[1];
                        outData[idx + 2] = color[2];
                        outData[idx + 3] = 255;
                    }
                }
            }
            
            ctx.putImageData(output, 0, 0);
            
            // 绘制线条
            drawCleanLines(ctx, data, mask, size, size, strokeIntensity);
            
            // 添加高光
            addIllustrationHighlights(ctx, size, size, palette);
            
            return canvas;
        }

        function extractSubject(data, width, height) {
            var mask = new Float32Array(width * height);
            var gray = new Float32Array(width * height);
            
            for (var i = 0; i < data.length; i += 4) {
                gray[i / 4] = data[i] * 0.299 + data[i + 1] * 0.587 + data[i + 2] * 0.114;
            }
            
            // 边缘密度
            for (var y = 2; y < height - 2; y++) {
                for (var x = 2; x < width - 2; x++) {
                    var idx = y * width + x;
                    var variance = 0;
                    var center = gray[idx];
                    
                    for (var dy = -2; dy <= 2; dy++) {
                        for (var dx = -2; dx <= 2; dx++) {
                            var diff = gray[(y + dy) * width + (x + dx)] - center;
                            variance += diff * diff;
                        }
                    }
                    
                    mask[idx] = variance > 400 ? 1 : 0;
                }
            }
            
            // 泛洪填充
            var visited = new Uint8Array(width * height);
            var queue = [];
            var cx = Math.floor(width / 2);
            var cy = Math.floor(height / 2);
            
            queue.push(cx, cy);
            visited[cy * width + cx] = 1;
            mask[cy * width + cx] = 1;
            
            var head = 0;
            while (head < queue.length) {
                var x = queue[head++];
                var y = queue[head++];
                var idx = y * width + x;
                
                var neighbors = [[x+1,y], [x-1,y], [x,y+1], [x,y-1]];
                for (var i = 0; i < neighbors.length; i++) {
                    var nx = neighbors[i][0];
                    var ny = neighbors[i][1];
                    if (nx >= 0 && nx < width && ny >= 0 && ny < height && !visited[ny * width + nx]) {
                        var nIdx = ny * width + nx;
                        if (Math.abs(gray[idx] - gray[nIdx]) < 50) {
                            visited[nIdx] = 1;
                            mask[nIdx] = 1;
                            queue.push(nx, ny);
                        }
                    }
                }
            }
            
            return mask;
        }

        function quantizeColors(data, mask, width, height, paletteColors, saturation) {
            var result = new Array(width * height);
            var satScale = saturation / 75;
            
            for (var i = 0; i < data.length; i += 4) {
                var idx = i / 4;
                
                if (mask[idx] < 0.5) {
                    result[idx] = [0, 0, 0];
                    continue;
                }
                
                var r = data[i];
                var g = data[i + 1];
                var b = data[i + 2];
                
                var minDist = Infinity;
                var bestColor = paletteColors[0];
                
                for (var j = 0; j < paletteColors.length; j++) {
                    var color = paletteColors[j];
                    var dr = r - color[0];
                    var dg = g - color[1];
                    var db = b - color[2];
                    var dist = dr * dr + dg * dg + db * db;
                    
                    if (dist < minDist) {
                        minDist = dist;
                        bestColor = color;
                    }
                }
                
                var mixRatio = 0.7 * satScale;
                result[idx] = [
                    Math.round(r * (1 - mixRatio) + bestColor[0] * mixRatio),
                    Math.round(g * (1 - mixRatio) + bestColor[1] * mixRatio),
                    Math.round(b * (1 - mixRatio) + bestColor[2] * mixRatio)
                ];
            }
            
            // 平滑处理
            var smoothed = new Array(width * height);
            for (var y = 1; y < height - 1; y++) {
                for (var x = 1; x < width - 1; x++) {
                    var idx = y * width + x;
                    if (mask[idx] < 0.5) {
                        smoothed[idx] = result[idx];
                        continue;
                    }
                    
                    var sr = 0, sg = 0, sb = 0, count = 0;
                    for (var dy = -1; dy <= 1; dy++) {
                        for (var dx = -1; dx <= 1; dx++) {
                            var nIdx = (y + dy) * width + (x + dx);
                            if (mask[nIdx] > 0.5 && result[nIdx]) {
                                sr += result[nIdx][0];
                                sg += result[nIdx][1];
                                sb += result[nIdx][2];
                                count++;
                            }
                        }
                    }
                    
                    if (count > 0) {
                        smoothed[idx] = [
                            Math.round(sr / count),
                            Math.round(sg / count),
                            Math.round(sb / count)
                        ];
                    } else {
                        smoothed[idx] = result[idx];
                    }
                }
            }
            
            // 填充边界
            for (var y = 0; y < height; y++) {
                for (var x = 0; x < width; x++) {
                    var idx = y * width + x;
                    if (!smoothed[idx]) {
                        smoothed[idx] = result[idx] || [255, 255, 255];
                    }
                }
            }
            
            return smoothed;
        }

        function drawCleanLines(ctx, data, mask, width, height, intensity) {
            var strokeWidth = Math.max(1, intensity / 25);
            var threshold = 255 - intensity * 1.5;
            
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            var edges = [];
            var gray = new Float32Array(width * height);
            
            for (var i = 0; i < data.length; i += 4) {
                gray[i / 4] = data[i] * 0.299 + data[i + 1] * 0.587 + data[i + 2] * 0.114;
            }
            
            for (var y = 1; y < height - 1; y += 2) {
                for (var x = 1; x < width - 1; x += 2) {
                    var idx = y * width + x;
                    if (mask[idx] < 0.5) continue;
                    
                    var gx = -gray[(y-1)*width + (x-1)] - 2*gray[y*width + (x-1)] - gray[(y+1)*width + (x-1)]
                           + gray[(y-1)*width + (x+1)] + 2*gray[y*width + (x+1)] + gray[(y+1)*width + (x+1)];
                           
                    var gy = -gray[(y-1)*width + (x-1)] - 2*gray[(y-1)*width + x] - gray[(y-1)*width + (x+1)]
                           + gray[(y+1)*width + (x-1)] + 2*gray[(y+1)*width + x] + gray[(y+1)*width + (x+1)];
                    
                    var mag = Math.sqrt(gx*gx + gy*gy);
                    
                    if (mag > threshold) {
                        edges.push({x: x, y: y, mag: mag});
                    }
                }
            }
            
            if (edges.length === 0) return;
            
            ctx.strokeStyle = '#3D3229';
            ctx.lineWidth = strokeWidth;
            
            ctx.beginPath();
            ctx.moveTo(edges[0].x, edges[0].y);
            for (var i = 1; i < edges.length; i++) {
                var prev = edges[i - 1];
                var curr = edges[i];
                var cpx = (prev.x + curr.x) / 2;
                var cpy = (prev.y + curr.y) / 2;
                ctx.quadraticCurveTo(prev.x, prev.y, cpx, cpy);
            }
            ctx.stroke();
        }

        function addIllustrationHighlights(ctx, width, height, palette) {
            var gradient1 = ctx.createRadialGradient(0, 0, 0, 0, 0, width * 0.6);
            gradient1.addColorStop(0, 'rgba(255, 255, 255, 0.15)');
            gradient1.addColorStop(1, 'transparent');
            ctx.fillStyle = gradient1;
            ctx.fillRect(0, 0, width, height);
            
            var imageData = ctx.getImageData(0, 0, width, height);
            var data = imageData.data;
            
            for (var i = 0; i < data.length; i += 4) {
                if (data[i + 3] > 0) {
                    var noise = (Math.random() - 0.5) * 4;
                    data[i] = Math.min(255, Math.max(0, data[i] + noise));
                    data[i + 1] = Math.min(255, Math.max(0, data[i + 1] + noise));
                    data[i + 2] = Math.min(255, Math.max(0, data[i + 2] + noise));
                }
            }
            
            ctx.putImageData(imageData, 0, 0);
        }

        function showSection(section) {
            document.getElementById('createSection').classList.toggle('hidden', section !== 'create');
            document.getElementById('gallerySection').classList.toggle('hidden', section !== 'gallery');
            
            var btns = document.querySelectorAll('.tab-btn');
            for (var i = 0; i < btns.length; i++) {
                if (btns[i].getAttribute('data-section') === section) {
                    btns[i].classList.remove('text-stone-400');
                    btns[i].classList.add('text-stone-800');
                } else {
                    btns[i].classList.add('text-stone-400');
                    btns[i].classList.remove('text-stone-800');
                }
            }
            
            if (section === 'gallery') {
                var activeTab = document.querySelector('.filter-tab.active');
                renderGallery(activeTab ? activeTab.getAttribute('data-filter') : 'all');
            }
        }

        function saveBadge() {
            if (!currentSketchData) return;
            document.getElementById('saveModal').classList.add('active');
            document.getElementById('badgeName').value = '';
            document.getElementById('badgeName').focus();
        }

        function closeModal() {
            document.getElementById('saveModal').classList.remove('active');
        }

        function confirmSave() {
            var name = document.getElementById('badgeName').value.trim() || '未命名徽章';
            var categoryLabels = { travel: '旅行', pet: '宠物', food: '美食', memory: '纪念' };
            var paletteLabels = { warm: '暖阳', fresh: '清新', soft: '柔和', vivid: '鲜艳', pastel: '马卡龙' };
            
            var badge = {
                id: Date.now(),
                name: name,
                category: currentCategory,
                categoryLabel: categoryLabels[currentCategory] || '其他',
                palette: currentPalette,
                paletteLabel: paletteLabels[currentPalette] || '默认',
                image: currentSketchData,
                createdAt: new Date().toLocaleDateString('zh-CN')
            };
            
            badges.unshift(badge);
            
            try {
                localStorage.setItem('beiji_badges', JSON.stringify(badges));
            } catch (e) {
                showToast('保存失败，存储空间可能已满');
                return;
            }
            
            closeModal();
            updateBadgeCount();
            showToast('"' + name + '" 已保存');
        }

        function downloadBadge() {
            if (!currentSketchData) return;
            var link = document.createElement('a');
            link.download = 'beiji-badge-' + Date.now() + '.png';
            link.href = currentSketchData;
            link.click();
        }

        function renderGallery(filter) {
            var grid = document.getElementById('badgeGrid');
            var empty = document.getElementById('galleryEmpty');
            var filtered = filter === 'all' ? badges : badges.filter(function(b) {
                return b.category === filter;
            });
            
            if (filtered.length === 0) {
                grid.innerHTML = '';
                empty.classList.remove('hidden');
                return;
            }
            
            empty.classList.add('hidden');
            var html = '';
            for (var i = 0; i < filtered.length; i++) {
                var badge = filtered[i];
                html += '<div class="badge-card">' +
                    '<div class="delete-btn" onclick="deleteBadge(' + badge.id + ', event)">×</div>' +
                    '<div class="aspect-square bg-gradient-to-br from-stone-50 to-yellow-50/20 p-6 flex items-center justify-center">' +
                        '<img src="' + badge.image + '" class="w-full h-full object-contain drop-shadow-xl rounded-2xl">' +
                    '</div>' +
                    '<div class="p-5">' +
                        '<h4 class="text-base font-normal mb-2 truncate">' + badge.name + '</h4>' +
                        '<div class="flex justify-between items-center">' +
                            '<div class="flex gap-2">' +
                                '<span class="text-xs px-2 py-1 bg-yellow-100 text-yellow-700 rounded-full">' + badge.categoryLabel + '</span>' +
                                '<span class="text-xs px-2 py-1 bg-stone-100 text-stone-500 rounded-full">' + badge.paletteLabel + '</span>' +
                            '</div>' +
                            '<span class="text-xs text-stone-300 font-en">' + badge.createdAt + '</span>' +
                        '</div>' +
                    '</div>' +
                '</div>';
            }
            grid.innerHTML = html;
        }

        function deleteBadge(id, event) {
            event.stopPropagation();
            if (confirm('确定要删除这个徽章吗？')) {
                badges = badges.filter(function(b) {
                    return b.id !== id;
                });
                try {
                    localStorage.setItem('beiji_badges', JSON.stringify(badges));
                } catch (e) {}
                updateBadgeCount();
                var activeTab = document.querySelector('.filter-tab.active');
                renderGallery(activeTab ? activeTab.getAttribute('data-filter') : 'all');
                showToast('徽章已删除');
            }
        }

        function updateBadgeCount() {
            var count = badges.length;
            var el = document.getElementById('badgeCount');
            el.textContent = count;
            if (count === 0) {
                el.classList.add('hidden');
            } else {
                el.classList.remove('hidden');
            }
        }

        function showToast(msg) {
            var toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(function() {
                toast.classList.remove('show');
            }, 2500);
        }

        document.getElementById('saveModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>
